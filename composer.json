{
    "name": "avathar/bbdkp",
    "type": "phpbb-extension",
    "description": "DKP (Dragon Kill Points) system for phpBB 3.3, integrating with bbGuild for guild/character management and bbAccounts for canonical double-entry point storage.",
    "homepage": "https://github.com/avatharbe/bbDKP",
    "version": "2.0.0-alpha2",
    "time": "2026-05-26",
    "keywords": ["phpbb", "extension", "dkp", "raid", "loot", "guild"],
    "license": "GPL-2.0-only",
    "authors": [
        {
            "name": "Andreas Vandenberghe",
            "homepage": "https://www.avathar.be/forum",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.1",
        "composer/installers": "~1.0"
    },
    "extra": {
        "display-name": "bbDKP",
        "soft-require": {
            "phpbb/phpbb": ">=3.3.0,<3.4.0@dev"
        }
    }
}
